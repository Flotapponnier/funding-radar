{
  "name": "funding-radar",
  "version": "0.1.0",
  "description": "Real-time Telegram bot that detects funding rate divergences across 7 perp venues (Binance, Bybit, OKX, Hyperliquid, Lighter, Gate, Deribit) — powered by Mobula's WebSocket.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "test:wss": "tsx src/test-wss.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "funding-rate",
    "arbitrage",
    "telegram-bot",
    "mobula",
    "perpetuals",
    "defi",
    "cefi",
    "hyperliquid",
    "lighter",
    "websocket",
    "trading-bot",
    "cash-and-carry",
    "basis-trade"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
