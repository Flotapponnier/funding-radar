# Mobula API key — get one at https://mobula.io
MOBULA_API_KEY=mob_xxxxxxxxxxxxx

# Telegram bot — create via @BotFather, then send /start to your bot
# and grab your chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=987654321

# Alert tuning
ALERT_THRESHOLD_APR=20         # alert when spread > N% APR
ALERT_COOLDOWN_MIN=15          # minutes between alerts for the same pair

# What to watch
WATCHED_SYMBOLS=BTC,ETH,SOL,HYPE
WATCHED_EXCHANGES=binance,bybit,hyperliquid,lighter,okx

# Storage & logs
DB_PATH=./bot.db
LOG_LEVEL=info
